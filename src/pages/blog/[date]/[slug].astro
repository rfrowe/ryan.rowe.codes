---
import { getCollection, render, type CollectionEntry } from "astro:content"
import { formatPostDate } from "@lib/blog"
import BlogPost from "@layouts/BlogPost.astro"
import { mdxComponents } from "@components/mdx-components"

// The hello-world post is a QUINE that renders its OWN full source (see CodeBlock.tsx).
// The content collection's `entry.body` strips the YAML frontmatter, but the pre-migration
// site rendered the whole file including it -- so import each post's raw bytes (`?raw`,
// frontmatter and all) and hand that to the MDX as `source`, restoring the frontmatter in
// the quine. `entry.body` is the fallback if a post's file can't be matched.
const rawSources = import.meta.glob<string>("/src/content/blog/**/*.mdx", {
  query: "?raw",
  import: "default",
  eager: true,
})

export async function getStaticPaths() {
  const posts = await getCollection("blog")

  return posts.map(post => ({
    params: {
      date: formatPostDate(post.data.created_at),
      slug: post.data.slug,
    },
    props: { post },
  }))
}

interface Props {
  post: CollectionEntry<"blog">
}

const { post } = Astro.props
const { Content } = await render(post)
const fullSource = (post.filePath && rawSources[`/${post.filePath}`]) || post.body
---

<BlogPost title={post.data.title}>
  <Content components={mdxComponents} source={fullSource} />
</BlogPost>
