---
import { getCollection } from "astro:content";
import Base from "@layouts/Base.astro";
import HeadlineCycler, { type HeadlinePost } from "@components/HeadlineCycler";
import SkylineAnchors from "@components/SkylineAnchors";
import { formatPostDate } from "@lib/blog";
import * as styles from "@styles/home.css.ts";

const posts = await getCollection("blog");
const headlinePosts: HeadlinePost[] = posts.map(post => ({
  headline: post.data.headline,
  href: `/blog/${formatPostDate(post.data.created_at)}/${post.data.slug}`,
}));
---

<Base title="ryan.rowe.codes">
  <div class={styles.container}>
    <div class={styles.banner}>
      <h1 class={styles.heading1}>
        Ryan <br />
        Rowe <br />
        Codes
      </h1>
      <h3 class={styles.heading3}>
        <HeadlineCycler client:load posts={headlinePosts} />
      </h3>
    </div>
    <div class={styles.image}>
      <SkylineAnchors client:load />
    </div>
  </div>
</Base>
