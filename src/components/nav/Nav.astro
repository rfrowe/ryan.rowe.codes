---
import NavLink from "./NavLink.astro";
import ThemeToggle from "./ThemeToggle";
import * as styles from "./Nav.css.ts";

const isRoot = Astro.url.pathname === "/";
---

<header class={styles.bar} id="site-nav" data-hidden="false">
  <nav class={styles.toolbar}>
    <ThemeToggle client:only="react" />

    <NavLink
      href="https://github.com/rfrowe"
      aria-label="Check out my GitHub"
      class={styles.iconLink}
    >
      <svg class={styles.icon} viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M12 1.27a11 11 0 00-3.48 21.46c.55.09.73-.28.73-.55v-1.84c-3.03.64-3.67-1.46-3.67-1.46-.55-1.29-1.28-1.65-1.28-1.65-.92-.65.1-.65.1-.65 1.1 0 1.73 1.1 1.73 1.1.92 1.65 2.57 1.2 3.21.92a2 2 0 01.64-1.47c-2.47-.27-5.04-1.19-5.04-5.5 0-1.1.46-2.1 1.2-2.84a3.76 3.76 0 010-2.93s.91-.28 3.11 1.1c1.8-.49 3.7-.49 5.5 0 2.1-1.38 3.02-1.1 3.02-1.1a3.76 3.76 0 010 2.93c.83.74 1.2 1.74 1.2 2.94 0 4.21-2.57 5.13-5.04 5.4.45.37.82.92.82 2.02v3.03c0 .27.1.64.73.55A11 11 0 0012 1.27"
        />
      </svg>
    </NavLink>

    <NavLink
      href="mailto:ryan@rowe.codes"
      aria-label="Send me an email"
      class={`${styles.iconLink} ${styles.emailTrigger}`}
    >
      <svg class={styles.icon} viewBox="0 0 24 24" aria-hidden="true">
        <path
          d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2m0 4-8 5-8-5V6l8 5 8-5z"
        />
      </svg>
    </NavLink>

    {!isRoot && (
      <>
        <NavLink href="/" class={`${styles.iconLink} ${styles.showOnMobile}`}>
          <svg class={styles.icon} viewBox="0 0 24 24" aria-hidden="true">
            <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" />
          </svg>
        </NavLink>

        <NavLink
          href="/"
          class={`${styles.textLink} ${styles.showOnDesktop} ${styles.homeLink}`}
        >
          {"ryan"}<span class={styles.at}>@</span><span class={styles.dot}>.</span>{"rowe"}.{"codes"}
        </NavLink>
      </>
    )}

    <span class={styles.spacer}>
      <NavLink href="/blog" class={styles.textLink}>Blog</NavLink>
      <NavLink href="/about" class={styles.textLink}>About</NavLink>
    </span>
  </nav>
</header>

<script>
  // Reproduces MUI's `useScrollTrigger({ threshold: 25 })` default hysteresis: hide only
  // while actively scrolling *down* past the threshold; any upward scroll shows the bar
  // again immediately, regardless of absolute position. Plain listener, no framework --
  // this is the only piece of nav JS besides the theme toggle island.
  const bar = document.getElementById("site-nav");
  if (bar) {
    const threshold = 25;
    let previous = window.scrollY;

    window.addEventListener(
      "scroll",
      () => {
        const current = window.scrollY;
        const hidden = current > previous && current > threshold;
        bar.dataset.hidden = String(hidden);
        previous = current;
      },
      { passive: true },
    );
  }
</script>
