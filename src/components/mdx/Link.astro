---
import { isExternalHref } from "@lib/util";
import * as styles from "./Prose.css.ts";

interface Props {
  href?: string;
  class?: string;
}

/**
 * Reproduces `gatsby-theme-material-ui`'s `Link` used by the pre-migration MDX overrides
 * (src/components/blog/overrides.tsx): external hrefs open in a new tab with
 * `rel="noopener noreferrer"`; internal ones (relative paths, hash anchors, `mailto:`,
 * same-origin absolute URLs) navigate in place, same as a plain anchor.
 */
const { href, class: className, ...rest } = Astro.props as Props;
const external = href !== undefined && isExternalHref(href, Astro.site?.hostname);
---

<a
  href={href}
  class:list={[styles.link, className]}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  {...rest}
>
  <slot />
</a>
