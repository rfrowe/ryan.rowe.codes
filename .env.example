# Copy to .env (git-ignored) for `docker compose up`.

# Required
ANTHROPIC_API_KEY=
GH_TOKEN=

# Optional -- override which repo/branch the container clones and tracks. Point these at a
# disposable fork while testing, to avoid pushing/opening PRs against the real repo.
GIT_REPO_URL=https://github.com/rfrowe/ryan.rowe.codes.git
GIT_BRANCH=main
